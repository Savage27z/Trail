# ---- BTL Runtime (required) ----------------------------------------------
# Your BTL runtime API key
BTL_API_KEY=

# Model name from the BTL docs (e.g. their flagship chat model)
BTL_MODEL=

# OpenAI-compatible base URL (default shown)
BTL_BASE_URL=https://api.badtheorylabs.com/v1

# true  = use native OpenAI tool-calling (primary path)
# false = ReAct fallback: model outputs strict JSON actions, parsed manually.
# Note: if the runtime rejects the tools param with a 4xx, Trail auto-falls
# back to ReAct for that investigation even when this is true.
BTL_USE_NATIVE_TOOLS=true

# ---- Data providers (required) --------------------------------------------
# Helius: https://dev.helius.xyz — RPC + parsed transaction history + DAS
HELIUS_API_KEY=

# Birdeye: https://docs.birdeye.so — token overview/security/price history
BIRDEYE_API_KEY=

# ---- Telegram (required for bot.py only; cli.py works without it) ---------
# From @BotFather
TELEGRAM_BOT_TOKEN=

# ---- Agent limits (optional, defaults shown) ------------------------------
# Max tool-calling rounds per investigation
TRAIL_MAX_ROUNDS=8
# Max wall-clock seconds per investigation
TRAIL_MAX_SECONDS=90
